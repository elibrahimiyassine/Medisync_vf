NODE_ENV=development
PORT=3000

DATABASE_URL="postgresql://postgres:12345678@localhost:5432/medisync"

JWT_SECRET=medisync_dev_access_secret_2024
JWT_REFRESH_SECRET=medisync_dev_refresh_secret_2024
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

CORS_ORIGIN=http://localhost:4200
FRONTEND_URL=http://localhost:4200

COOKIE_SECRET=medisync_cookie_secret_2024

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM="MediSync <noreply@medisync.com>"

UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=20

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100
DISABLE_RATE_LIMIT=true

TOTP_ISSUER=MediSync
LOG_LEVEL=info
