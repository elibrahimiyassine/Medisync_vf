# ─────────────────────────────────────────────────
#  MediSync Backend — Environment Variables
# ─────────────────────────────────────────────────

# Node
NODE_ENV=development
PORT=3000

# Database (PostgreSQL via Prisma)
DATABASE_URL="postgresql://medisync:medisync_secret@localhost:5432/medisync"

# JWT
JWT_ACCESS_SECRET=your_super_secret_access_key_change_me
JWT_REFRESH_SECRET=your_super_secret_refresh_key_change_me
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:4200

# Cookie
COOKIE_SECRET=your_cookie_secret_change_me

# Email (Nodemailer — SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM="MediSync <noreply@medisync.com>"

# File uploads
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=10

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=10

# 2FA (TOTP)
TOTP_ISSUER=MediSync

# Logging
LOG_LEVEL=info

# Frontend URL (used in password reset emails)
FRONTEND_URL=http://localhost:4200

# pgAdmin (Docker only)
PGADMIN_EMAIL=admin@medisync.com
PGADMIN_PASSWORD=admin
